        {
          "name": "GET Todos los Clientes",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/clientes", "host": ["{{baseUrl}}"], "path": ["clientes"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                "pm.test('Respuesta es un array', () => {",
                "  const body = pm.response.json();",
                "  pm.expect(body).to.be.an('array');",
